{
  "name": "staunch-antd-design-system-kit",
  "version": "0.1.0",
  "description": "CLI that scaffolds Ant Design v6, a design-token theme system, a /design-system showcase page, and a live /theme-editor into a Next.js (App Router) or Vite + React + TypeScript project.",
  "keywords": [
    "antd",
    "ant-design",
    "design-system",
    "nextjs",
    "vite",
    "cli",
    "scaffold",
    "theme-editor",
    "component-library"
  ],
  "license": "MIT",
  "author": "imranhayat",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Staunchglobal/antd-design-system-kit.git"
  },
  "homepage": "https://github.com/Staunchglobal/antd-design-system-kit#readme",
  "bugs": {
    "url": "https://github.com/Staunchglobal/antd-design-system-kit/issues"
  },
  "private": true,
  "type": "module",
  "bin": {
    "antd-design-kit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "build:registry": "node scripts/build-registry.mjs",
    "build:token-schema": "node scripts/extract-token-schema.mjs",
    "build:component-token-schema": "node scripts/extract-component-token-schema.mjs",
    "build:icon-reexports": "node scripts/generate-icon-reexports.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke-test.mjs",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.1",
    "@types/prompts": "^2.4.9",
    "antd": "^6.5.0",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.18"
  }
}
